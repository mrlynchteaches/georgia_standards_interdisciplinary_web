+ if (/^(03)-(05|5)$/.test(compact)) {
+ return ['03', '04', '05'];
+ }
+
+ if (/^(06|6)-(08|8)$/.test(compact)) {
+ return ['06', '07', '08'];
+ }
+
+ if (/^(09|9)-12$/.test(compact)) {
+ return ['09', '10', '11', '12'];
+ }
+
+ return [normalizeEducationToken(raw)];
